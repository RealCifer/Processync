# Backend Settings
PROJECT_NAME="Processync AI"

# ⚠️  Use port 5433 because Docker remaps Postgres to 5433 to avoid conflict with
# any local Postgres installation that is already on 5432.
DATABASE_URL=postgresql://user:password@localhost:5433/processync
REDIS_URL=redis://localhost:6379/0

# Docker PostgreSQL (must match DATABASE_URL credentials above)
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=processync

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
